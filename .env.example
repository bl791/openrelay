# ─── Shared ──────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=openrelay
POSTGRES_PASSWORD=openrelay
POSTGRES_DB=openrelay
DATABASE_URL=postgres://openrelay:openrelay@localhost:5432/openrelay

# ─── API control plane (apps/api) ────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
# 32+ character secret used to sign JWT session tokens. CHANGE THIS in production.
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d
# Base URL the engine control API is reachable at from the API.
ENGINE_URL=http://localhost:8090
# Shared bearer secret the API uses to authenticate to the engine control API.
ENGINE_TOKEN=change-me-engine-shared-secret
# Browser-reachable base URL of the API. Clip media is proxied through it, so it
# must be the URL the browser uses to reach the API.
API_PUBLIC_URL=http://localhost:4000
# Public host streamers point their encoders at (shown in the dashboard).
PUBLIC_INGEST_HOST=localhost
# RTMP/SRT ingest ports advertised in push URLs (must match MediaMTX's).
RTMP_PORT=1935
SRT_PORT=8890
# S3/MinIO object storage for the clips & BRB media library. Uploads and playback
# are proxied through the API, so these are the API's server-side credentials and
# the engine's in-network endpoint (not browser-reachable).
S3_ENDPOINT=http://localhost:9000
# Base URL the engine reads clip media from (in-network; = S3_ENDPOINT in compose).
S3_PUBLIC_URL=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=openrelay-media
S3_ACCESS_KEY=openrelay
S3_SECRET_KEY=openrelay-secret

# ─── Twitch clip import (apps/api, optional) ─────────────────────────────────
# Leave blank to disable the "import Twitch clips for BRB" feature. To enable,
# register an app at https://dev.twitch.tv/console and set the OAuth redirect to
# ${API_PUBLIC_URL}/api/twitch/callback.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Optional overrides (sensible defaults are derived if omitted):
# TWITCH_REDIRECT_URI=http://localhost:4000/api/twitch/callback
# Key for encrypting stored OAuth tokens at rest; defaults to JWT_SECRET if unset.
# TOKEN_ENCRYPTION_KEY=
# Web dashboard URL the OAuth callback redirects back to.
WEB_APP_URL=http://localhost:3000

# ─── Relay engine (apps/engine) ──────────────────────────────────────────────
ENGINE_PORT=8090
ENGINE_HOST=0.0.0.0
# Set to "1" to use the simulated FFmpeg driver instead of spawning real FFmpeg.
ENGINE_SIMULATE=0
# Directory for fallback/BRB media assets.
MEDIA_DIR=/var/lib/openrelay/media
LOG_LEVEL=info

# ─── Web dashboard (apps/web) ────────────────────────────────────────────────
WEB_PORT=3000
# Browser-visible base URL of the API. In docker-compose this is the host port.
NEXT_PUBLIC_API_URL=http://localhost:4000
