{
  "name": "@openrelay/api",
  "version": "0.1.0",
  "private": true,
  "description": "Fastify HTTP control-plane API for OpenRelay: auth, persistence and engine orchestration.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "bin": {
    "openrelay-api": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.726.0",
    "@aws-sdk/s3-request-presigner": "^3.726.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.0.3",
    "@fastify/multipart": "^9",
    "@fastify/sensible": "^6.0.2",
    "@openrelay/core": "workspace:*",
    "@openrelay/db": "workspace:*",
    "@paralleldrive/cuid2": "^2.2.2",
    "argon2": "^0.41.1",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.2",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@openrelay/config": "workspace:*",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
